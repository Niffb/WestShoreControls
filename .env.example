# Web3Forms access key for Request Quote form
# 1. Go to https://web3forms.com
# 2. Enter the email you want quote requests sent to
# 3. Copy the access key from the confirmation email
NEXT_PUBLIC_WEB3FORMS_KEY=your_access_key_here

# Comma-separated list of CC recipients for quote requests
NEXT_PUBLIC_WEB3FORMS_CC=mmarelic@westshorecontrols.com,mjesty@westshorecontrols.com
